body{
font-family:Segoe UI;
background:#f4f7fb;
margin:0;
}

header{
background:linear-gradient(90deg,#0f4c81,#1f7bbf);
color:white;
text-align:center;
padding:25px;
font-size:26px;
font-weight:600;
}

.container{
max-width:1000px;
margin:auto;
padding:25px;
display:grid;
grid-template-columns:1fr 1fr;
gap:20px;
}

.card{
background:white;
padding:25px;
border-radius:14px;
box-shadow:0 5px 20px rgba(0,0,0,0.08);
}

button{
background:#1f7bbf;
border:none;
color:white;
padding:12px 20px;
border-radius:10px;
font-size:15px;
cursor:pointer;
}

#timer{
font-size:60px;
text-align:center;
font-weight:700;
color:#1f7bbf;
}

#voltas{
font-size:40px;
text-align:center;
font-weight:600;
}
